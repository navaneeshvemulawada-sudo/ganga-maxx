# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Security
SECRET_KEY=dev_secret_key_change_me_in_production
JWT_SECRET_KEY=dev_jwt_secret_key_change_me_in_production
JWT_ACCESS_TOKEN_EXPIRES=86400  # 24 hours in seconds

# Database Configuration
# Fallback local development SQLite:
DATABASE_URL=sqlite:///ganga_maxx.db

# Production / PostgreSQL Configuration (Uncomment and edit for PostgreSQL):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ganga_maxx
